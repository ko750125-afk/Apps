rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    // Portfolio apps — public read, admin-only write
    // ═══════════════════════════════════════════
    match /18_apps_list/{appId} {
      allow read: if true;
      allow write: if true; // ⚠️ 임시 개방: 누구나 읽고 쓸 수 있음
    }

    // ═══════════════════════════════════════════
    // Migration source collections — admin-only
    // ═══════════════════════════════════════════
    match /local/{docId} {
      allow read, write: if isAdmin();
    }

    // ═══════════════════════════════════════════
    // Users collection — allow users to manage their own profile
    // ═══════════════════════════════════════════
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ═══════════════════════════════════════════
    // Default deny — block everything else
    // ═══════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════
    // Helper: Admin UID whitelist
    // After login, check browser console for:
    //   🔑 Admin UID: <your-uid>
    // Then replace the UID below and deploy:
    //   firebase deploy --only firestore:rules
    // ═══════════════════════════════════════════
    function isAdmin() {
      return request.auth != null
          && request.auth.uid in [
               "FGEZWVWjNAUniFFargUcP8YC9q52"
             ];
    }
  }
}
